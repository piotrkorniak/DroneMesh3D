#!/bin/sh
# Pre-commit hook: code cleanup + lint verification
# Install: git config core.hooksPath hooks
#
# Runs CleanupCode on staged C# files and ESLint on staged Web files.
# If formatter modifies files, commit is rejected — add the changes and retry.

set -e

echo "=== Pre-commit: Code formatting check ==="

# Get staged files (only added/modified, not deleted)
STAGED_CS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.cs$' || true)
STAGED_TS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|html)$' | grep '^Web/' || true)

# --- C# CleanupCode ---
if [ -n "$STAGED_CS" ]; then
  echo "Running CleanupCode on staged C# files..."
  dotnet jb cleanupcode DroneMesh3D.slnx \
    --include="$(echo "$STAGED_CS" | tr '\n' ';')" \
    --profile="Built-in: Reformat Code" \
    --dotnetcore="C:/Program Files/dotnet/dotnet.exe" \
    --no-build 2>/dev/null

  # Check if cleanupcode modified any files
  CHANGED_CS=$(git diff --name-only -- $STAGED_CS)
  if [ -n "$CHANGED_CS" ]; then
    echo ""
    echo "ERROR: The following C# files need formatting:"
    echo "$CHANGED_CS"
    echo ""
    echo "CleanupCode has auto-fixed them. Run 'git add' on the changes and commit again."
    exit 1
  fi
fi

# --- ESLint ---
if [ -n "$STAGED_TS" ]; then
  echo "Running ESLint on staged Web files..."
  # Convert paths from Web/src/... to src/... for eslint
  FILES_FOR_LINT=$(echo "$STAGED_TS" | sed 's|^Web/||' | tr '\n' ' ')
  (cd Web && npx eslint --max-warnings=0 $FILES_FOR_LINT)
  if [ $? -ne 0 ]; then
    echo ""
    echo "ERROR: ESLint found errors. Fix them before committing."
    exit 1
  fi
fi

echo "=== Pre-commit: All checks passed ==="
