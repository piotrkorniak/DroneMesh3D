#!/bin/sh
# Pre-commit hook: format check only (fast)
# Build and tests run in pre-push hook and CI.
# Install: git config core.hooksPath hooks (auto-installed by dotnet build)

set -e

echo "=== Pre-commit: Code formatting check ==="

# Get staged C# files (only added/modified, not deleted)
STAGED_CS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.cs$' || true)

# --- dotnet format ---
if [ -n "$STAGED_CS" ]; then
  echo "Running dotnet format on staged C# files..."
  if ! dotnet format DroneMesh3D.slnx \
    --include $(echo "$STAGED_CS" | tr '\n' ' ') \
    --verify-no-changes 2>/dev/null; then
    echo ""
    echo "ERROR: The above C# files need formatting."
    echo "Run 'dotnet format DroneMesh3D.slnx' to fix, then stage the changes."
    exit 1
  fi
fi

echo "=== Pre-commit: All checks passed ==="
