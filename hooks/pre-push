#!/bin/sh
# Pre-push hook: build + tests
# Runs before pushing to catch broken code before it hits CI.

set -e

echo "=== Pre-push: Build ==="

echo "Building .NET solution..."
dotnet build DroneMesh3D.slnx --configuration Release --nologo -v q

echo "=== Pre-push: Tests ==="

echo "Running .NET tests..."
dotnet test DroneMesh3D.slnx --configuration Release --no-build --nologo -v q

echo "=== Pre-push: All checks passed ==="
